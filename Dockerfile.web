# ─── Stage 1: build ──────────────────────────────────────────────────────────
FROM golang:1.25-alpine AS builder

RUN apk add --no-cache git ca-certificates

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build \
    -ldflags="-s -w" \
    -o /out/gobot-web \
    ./cmd/web

# ─── Stage 2: runtime ────────────────────────────────────────────────────────
FROM alpine:3.21

RUN apk add --no-cache ca-certificates tzdata

RUN addgroup -S gobot-web && adduser -S gobot-web -G gobot-web

WORKDIR /app

COPY --from=builder /out/gobot-web .

USER gobot-web

EXPOSE 8081

ENTRYPOINT ["/app/gobot-web"]
